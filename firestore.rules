rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection: Users can read/write their own profile, admins can read all
    match /users/{userId} {
      allow read, write: if request.auth != null && 
        (request.auth.uid == userId || request.auth.token.role == 'admin');
    }

    // Dresses collection: Admins can do anything, clients can only access dresses they created or are assigned to
    match /dresses/{dressId} {
      allow read, write: if request.auth != null && 
        (request.auth.token.role == 'admin' || resource.data.createdBy == request.auth.uid);
      allow create: if request.auth != null && 
        (request.auth.token.role == 'admin' || request.auth.uid == resource.data.createdBy);
    }
  }
}
